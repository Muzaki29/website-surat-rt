# Salin ke .env lalu sesuaikan
DATABASE_URL="file:./dev.db"
AUTH_SECRET="ganti-dengan-string-acak-minimal-32-karakter"
AUTH_URL="http://localhost:3000"

# Opsional — Midtrans (pembayaran online)
# MIDTRANS_SERVER_KEY=
# MIDTRANS_CLIENT_KEY=
# MIDTRANS_IS_PRODUCTION=false
# NEXT_PUBLIC_MIDTRANS_SNAP_URL=https://app.sandbox.midtrans.com/snap/snap.js

# Opsional — notifikasi WhatsApp
# WHATSAPP_API_URL=
# WHATSAPP_API_TOKEN=
# WHATSAPP_DEFAULT_PHONE=08xxxxxxxxxx

# Opsional — email transaksional (reset password, pengingat iuran)
# EMAIL_API_URL=https://api.resend.com/emails
# EMAIL_API_KEY=
# EMAIL_FROM=SuratRT <noreply@rt005.local>

# Opsional — cron pengingat iuran (header x-cron-secret)
# CRON_SECRET=ganti-dengan-string-acak
# IURAN_REMINDER_DAYS=7,3,1

# Opsional — multi-RT (slug konfigurasi di RtConfig)
# RT_SLUG=rt005

# Hanya development — tampilkan link reset di response API (jangan aktifkan di produksi)
# DEBUG_RESET=true
